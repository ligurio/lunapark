{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "workspace": {
    "workspace_roots": [ "tests" ]
  },
  "runtime": {
    "version": "LuaJIT"
  },
  "diagnostics": {
    "disable": [
      "access-invisible",
      "deprecated",
      "unnecessary-assert",
      "unnecessary-if",
      "unresolved-require",
      "unused"
    ]
  }
}
